# Debe apuntar a la misma base de datos que packages/database.
DATABASE_URL="postgresql://nogal:nogal@localhost:5432/nogal?schema=public"

PORT=4000
NODE_ENV=development

# Generar valores aleatorios largos y distintos para cada entorno, p. ej.:
#   openssl rand -base64 48
JWT_ACCESS_SECRET="reemplaza-esto-con-un-secreto-aleatorio-de-al-menos-32-caracteres"
JWT_REFRESH_SECRET="reemplaza-esto-con-otro-secreto-aleatorio-de-al-menos-32-caracteres"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN_DAYS=30

# Origen permitido para CORS y usado para construir enlaces de verificación
# de correo / restablecimiento de contraseña.
WEB_APP_URL="http://localhost:3000"

# URL pública de esta misma API, usada para construir las URLs de imágenes.
API_URL="http://localhost:4000"

# Almacenamiento de imágenes: "local" (disco, solo dev) o "r2" (Cloudflare
# R2, producción) — ver modules/storage.
STORAGE_PROVIDER="local"
UPLOADS_DIR="./uploads"

# Solo si STORAGE_PROVIDER="r2":
# R2_ACCOUNT_ID="tu-account-id-de-cloudflare"
# R2_ACCESS_KEY_ID="tu-access-key-id"
# R2_SECRET_ACCESS_KEY="tu-secret-access-key"
# R2_BUCKET_NAME="nogal-media"
# R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# Correo transaccional: "log" (solo consola, dev) o "resend" (producción).
MAIL_PROVIDER="log"
MAIL_FROM="Nogal <onboarding@resend.dev>"
# Solo si MAIL_PROVIDER="resend":
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
